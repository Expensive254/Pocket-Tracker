<div class="app-container" id="app">
    <!-- Splash Screen -->
    <div id="splash">
        <i class="fa-solid fa-wallet splash-logo"></i>
        <h1>PocketTrack</h1>
        <p>Your Smart Expense Manager</p>
    </div>

    <!-- Onboarding -->
    <div id="onboarding" class="hidden">
        <div class="onboarding-slides" id="onboarding-slider">
            <div class="slide">
                <i class="fa-solid fa-chart-pie slide-icon"></i>
                <h2>Track Expenses</h2>
                <p>Keep a record of all your spending in one safe place easily and accurately.</p>
            </div>
            <div class="slide">
                <i class="fa-solid fa-bullseye slide-icon"></i>
                <h2>Control Budget</h2>
                <p>Set a monthly budget and stay within limits to save more money.</p>
            </div>
            <div class="slide">
                <i class="fa-solid fa-chart-line slide-icon"></i>
                <h2>Analyze Spending</h2>
                <p>View detailed charts and statistics to understand your financial habits.</p>
            </div>
        </div>
        <div class="onboarding-controls">
            <button class="btn-text" onclick="app.skipOnboarding()">Skip</button>
            <div class="dots" id="onboarding-dots">
                <div class="dot active"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
            <button class="btn-primary" id="btn-next-onboarding" onclick="app.nextOnboarding()">Next</button>
        </div>
    </div>

    <!-- Setup Screen -->
    <div id="setup" class="hidden">
        <h2 style="margin-bottom: 10px;">Welcome!</h2>
        <p style="margin-bottom: 30px;">Let's set up your profile to get started.</p>
        
        <div class="form-group">
            <label>Your Name</label>
